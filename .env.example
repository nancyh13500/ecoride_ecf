# Configuration SMTP pour l'envoi d'emails de contact
# À configurer sur le serveur de production

# Serveur SMTP (Gmail, Brevo, etc.)
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587

# Identifiants SMTP
SMTP_USER=votre-email@gmail.com
SMTP_PASSWORD=votre-mot-de-passe-application

# Email expéditeur
MAIL_FROM=noreply@ecoride.fr
MAIL_FROM_NAME=EcoRide

# Email destinataire pour les messages de contact
CONTACT_EMAIL=contact@ecoride.fr