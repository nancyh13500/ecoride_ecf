# Redirige toutes les requêtes vers le dossier public (document root applicatif)
RewriteEngine On

# Bloquer l'accès direct aux dossiers sensibles hors public
RewriteRule ^(lib|src|test|database|docs|scripts|config|vendor|docker|templates|bootstrap)(/|$) - [F,L]

# Ne pas réécrire si le fichier existe déjà dans public
RewriteCond %{DOCUMENT_ROOT}/public%{REQUEST_URI} -f [OR]
RewriteCond %{DOCUMENT_ROOT}/public%{REQUEST_URI} -d
RewriteRule ^(.*)$ public/$1 [L]

# Fallback vers public pour le reste
RewriteRule ^(.*)$ public/$1 [L]
